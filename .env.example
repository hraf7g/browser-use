# Copy this file to `.env` for local development only.
# Do not commit real secrets. For AWS production, use SSM Parameter Store or Secrets Manager
# and inject values into the runtime environment instead of storing them in the repo or `.venv`.

# Backend
UTW_ENVIRONMENT=development
UTW_DEBUG=false
UTW_HOST=0.0.0.0
UTW_PORT=8000
UTW_DATABASE_URL=postgresql+psycopg://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@CHANGE_ME_DB_HOST:5432/CHANGE_ME_DB_NAME
UTW_AUTH_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_VALUE
UTW_AUTH_ISSUER=utw-api
UTW_AUTH_AUDIENCE=utw-users
UTW_AUTH_ACCESS_TOKEN_TTL_MINUTES=60
UTW_AUTH_COOKIE_NAME=utw_access_token
UTW_AUTH_COOKIE_PATH=/
UTW_AUTH_COOKIE_DOMAIN=
UTW_AUTH_COOKIE_SAME_SITE=lax
UTW_AUTH_COOKIE_SECURE=false
UTW_PASSWORD_RESET_TOKEN_TTL_MINUTES=60
UTW_FRONTEND_BASE_URL=http://127.0.0.1:3000
UTW_CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173
UTW_OPERATOR_API_KEY=CHANGE_ME_OPERATOR_API_KEY
UTW_EMAIL_DELIVERY_BACKEND=dev_outbox
UTW_EMAIL_SENDER=alerts@example.com
UTW_EMAIL_REPLY_TO=
UTW_EMAIL_SES_CONFIGURATION_SET=
UTW_EMAIL_SES_FROM_ARN=
UTW_AWS_REGION=us-east-1
UTW_AI_PROVIDER=disabled
UTW_AI_MODEL=anthropic.claude-sonnet-4-6
UTW_AI_FALLBACK_MODEL=anthropic.claude-haiku-4-5
UTW_AI_BEDROCK_USE_AMBIENT_CREDENTIALS=true
UTW_AI_MAX_TOKENS=8192
UTW_AI_TEMPERATURE=0.0
UTW_AI_SUMMARY_BATCH_SIZE=25
UTW_AI_SUMMARY_MAX_ATTEMPTS=3
UTW_AI_DAILY_REQUEST_BUDGET=500
UTW_AI_DAILY_RESERVED_TOKEN_BUDGET=200000
UTW_BROWSER_AGENT_ENABLED=true
UTW_BROWSER_AGENT_DEFAULT_MAX_STEPS=25
UTW_BROWSER_AGENT_STEP_TIMEOUT_SECONDS=180
UTW_BROWSER_AGENT_LLM_TIMEOUT_SECONDS=90
UTW_BROWSER_AGENT_MAX_CONCURRENT_RUNS_PER_USER=1
UTW_BROWSER_AGENT_MAX_QUEUED_RUNS_PER_USER=3
UTW_BROWSER_AGENT_MAX_GLOBAL_RUNNING_RUNS=3
UTW_BROWSER_AGENT_WORKER_POLL_SECONDS=10
UTW_BROWSER_AGENT_WORKER_STALE_HEARTBEAT_SECONDS=900

# Frontend
# These NEXT_PUBLIC_* values are compiled into the production frontend build.
# Set them correctly before running `npm run build` for staging or AWS.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_AUTH_COOKIE_NAME=utw_access_token

# Browser-use agent runtime
BROWSER_USE_REQUIRE_EXPLICIT_LLM=true
DEFAULT_LLM=bedrock_anthropic:us.anthropic.claude-sonnet-4-20250514-v1:0
BROWSER_USE_AWS_REGION=us-east-1
